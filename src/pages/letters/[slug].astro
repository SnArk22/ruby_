---
import { getCollection, render } from 'astro:content';
import NewsletterPostLayout from '../../layouts/NewsletterPostLayout.astro';

export async function getStaticPaths() {
  const letters = await getCollection('NewsletterIndex');
  return letters.map(letter => ({
    params: { slug: letter.id }, 
    props: { letter },
  }));
}

const { letter } = Astro.props;
const { Content } = await render(letter);
---
<NewsletterPostLayout frontmatter={letter.data}>
  <Content />
</NewsletterPostLayout>